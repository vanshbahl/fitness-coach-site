# Environment Configuration
# Copy this file to .env and fill in the values

ENVIRONMENT="production"
DEBUG=False

# API Configuration
PROJECT_NAME="Quick Strength API"
VERSION="1.0.0"

# Security
# Generate a strong 32-byte secret key in production (e.g., using `openssl rand -hex 32`)
SECRET_KEY=""

# CORS Configuration
# Format as a JSON list string
BACKEND_CORS_ORIGINS=["https://quick-strength.vercel.app"]

# Database Configuration
# Production PostgreSQL Connection (Neon, Supabase, Render, etc.)
DATABASE_URL="postgresql+asyncpg://user:password@host/dbname"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
