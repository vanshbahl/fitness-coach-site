# ==============================================================================
# Python / Backend (FastAPI, SQLAlchemy)
# ==============================================================================
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
dist/
build/
*.egg-info/
.venv/
venv/
env/
.python-version

# ==============================================================================
# Node / React / Vite (Frontend)
# ==============================================================================
node_modules/
.vite/
coverage/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.eslintcache
# NOTE: package-lock.json is intentionally NOT ignored and must be tracked.

# ==============================================================================
# Environment Configuration
# ==============================================================================
# Ignore all environment files except the template
.env
.env.*
!.env.example

# ==============================================================================
# IDEs & Editor Configuration
# ==============================================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iws
*.iml
*.ipr

# Cursor & Antigravity
.cursor/
.cursorignore
.antigravity/
.agents/workspace.json

# ==============================================================================
# Operating Systems
# ==============================================================================
# macOS
.DS_Store
.AppleDouble
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Desktop.ini

# Linux
*~

# ==============================================================================
# Build Artifacts & Logs
# ==============================================================================
logs/
*.log
.cache/

# ==============================================================================
# Database
# ==============================================================================
# SQLite data files and journals
*.sqlite
*.sqlite3
*.db
*.db3
*sqlite3-journal
*-journal

# Local development database dumps
*.sql
*.dump
*.bak

# NOTE: PostgreSQL migration files (Alembic) MUST remain tracked.

# ==============================================================================
# Miscellaneous
# ==============================================================================
# Temporary / backup files
*.swp
*.swo
*.tmp
*.temp

# Generated reports
coverage-report/
